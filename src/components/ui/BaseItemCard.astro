---
import Icon from "./Icon.astro";
import { renderInlineMarkdown } from "../../utils/markdown";

interface Props {
    title: string;
    href: string;
    description?: string;
    date?: string;
    authors?: string;
    extraInput?: string;
    paperReference?: string;
    paperUrl?: string;
    tags?: string[];
    externalUrl?: string;
    externalLabel?: string;
}

const {
    title,
    href,
    description,
    date,
    authors,
    extraInput,
    paperReference,
    paperUrl,
    tags,
    externalUrl,
    externalLabel = "View external",
} = Astro.props;

const paperLinkIsExternal = paperUrl?.startsWith("http");
const descriptionHtml = description
    ? await renderInlineMarkdown(description)
    : undefined;
---

<article class="card">
    <div class="card-content">
        <a href={href} class="card-title">{title}</a>

        <div class="card-meta">
            {date && (
                <span class="flex items-center gap-1">
                    <Icon name="Calendar" size={24} />
                    <span>{date}</span>
                </span>
            )}
            {authors && (
                <span class="flex items-center gap-1">
                    <Icon name="User" size={24} />
                    <span>{authors}</span>
                </span>
            )}
            {extraInput && (
                <span class="flex items-center gap-1">
                    <Icon name="Institution" size={24} />
                    <span>{extraInput}</span>
                </span>
            )}
        </div>

        {paperReference && (
            <p class="paper-reference">
                <span>Paper:</span>{" "}
                {paperUrl ? (
                    <a
                        href={paperUrl}
                        target={paperLinkIsExternal ? "_blank" : undefined}
                        rel={paperLinkIsExternal ? "noopener noreferrer" : undefined}
                    >
                        {paperReference}
                    </a>
                ) : paperReference}
            </p>
        )}

        {tags && tags.length > 0 && (
            <p class="topics-line">Topics: {tags.join(", ")}</p>
        )}

        {descriptionHtml && <p class="card-desc" set:html={descriptionHtml} />}
    </div>

    {
        externalUrl && (
            <div class="flex-shrink-0">
                <a href={externalUrl} target="_blank" rel="noopener noreferrer" class="card-link">
                    {externalLabel}
                </a>
            </div>
        )
    }
</article>
